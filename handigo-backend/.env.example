NODE_ENV=production
PORT=5000

# Cơ sở dữ liệu
MONGO_URI=mongodb+srv://USER:PASSWORD@HOST/DATABASE

# Miền frontend được phép truy cập. FRONTEND_URLS dùng khi có nhiều miền.
FRONTEND_URL=https://app.example.com
FRONTEND_URLS=https://www.example.com

# Xác thực
ACCESS_TOKEN_SECRET=thay-bang-chuoi-ngau-nhien-dai
REFRESH_TOKEN_SECRET=thay-bang-chuoi-ngau-nhien-khac
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# OAuth
GOOGLE_CLIENT_ID=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Cloudinary
CLOUDINARY_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# PayOS
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
PAYOS_RETURN_URL=https://app.example.com/payment/success
PAYOS_CANCEL_URL=https://app.example.com/payment/cancel
PAYOS_WALLET_DEPOSIT_RETURN_URL=https://app.example.com/wallet/deposit/success
PAYOS_WALLET_DEPOSIT_CANCEL_URL=https://app.example.com/wallet/deposit/cancel

# Email
EMAIL_USER=
EMAIL_PASSWORD=
