      "name": "01 Auth - Login Customer",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('login customer returns token', function () {",
              "  pm.response.to.have.status(200);",
              "  const body = pm.response.json();",
              "  pm.expect(body.token).to.be.a('string').and.not.empty;",
              "  pm.collectionVariables.set('customerToken', body.token);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
