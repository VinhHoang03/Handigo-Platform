api/auth.api';\r\nimport type { LoginRequest } from '../types/auth.types';\r\nimport { useAuthStore } from '../store/auth.store';\r\n\r\nexport const authService = {\r\n  login: async (credentials: LoginRequest) => {\r\n    try {\r\n      const response = await loginApi(credentials);\r\n      \r\n      // Update store after successful login\r\n      const { user, token } = response;\r\n      useAuthStore.getState().setAuth(user, token);\r\n      \r\n      return response;\r\n    } catch (error: any) {\r\n      // Basic error handling or transformation can go here\r\n      const message = error.response?.data?.message || 'Failed to login';\r\n      throw new Error(message);\r\n    }\r\n  },\r\n\r\n  logout: () => {\r\n    useAuthStore.getState().logout();\r\n  }\r\n};\r\n","usedDeprecatedRules":[]},{"filePath":"D:\\DATN-SEP490\\wdp301-rbl-project-group6\\handigo-web\\src\\features\\auth\\store\\auth.store.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\DATN-SEP490\\wdp301-rbl-project-group6\\handigo-web\\src\\features\\auth\\types\\auth.types.ts","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\DATN-SEP490\\wdp301-rbl-project-group6\\handigo-web\\src\\features\\customer\\components\\CustomerHomeComponents.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\DATN-SEP490\\wdp301-rbl-project-group6\\handigo-web\\src\\features\\customer\\pages\\CustomerHomePage.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"D:\\DATN-SEP490\\wdp301-rbl-project-group6\\h